# Database Configuration
# Use the connection string from Supabase (Transaction Pooler or Session Pooler is recommended)
DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:6543/postgres

# Supabase API Settings
SUPABASE_URL=https://[project-id].supabase.co
SUPABASE_SERVICE_KEY=[service-role-key]


# Security Settings
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET=supersecretjwtkeychangeinproduction12345
JWT_EXPIRE_MINUTES=60

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
